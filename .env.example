# =============================================================================
# IEP Copilot - Environment Variables
# =============================================================================
# Copy this to .env.local for development

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For type generation
SUPABASE_PROJECT_ID=your-project-id

# -----------------------------------------------------------------------------
# Google Cloud (Document AI)
# -----------------------------------------------------------------------------
# Option 1: Service account JSON file path (local development)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option 2: Service account JSON as environment variable (for Vercel)
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

GCP_PROJECT_ID=iep-copilot-prod
DOCAI_LOCATION=us
DOCAI_PROCESSOR_ID=bc01c931f7141c68

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Optional: Specify model version (defaults to claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable server-side PDF rendering (requires poppler-utils and webp)
# Only enable this if deploying to an environment with these tools installed
# For Vercel, leave this false and use client-side PDF.js rendering instead
ENABLE_SERVER_PDF_RENDER=false

# Enable fuzzy quote verification for messy OCR documents
# When false (default), only exact and normalized matches are accepted
# When true, uses Levenshtein-based fuzzy matching (with performance guards)
ENABLE_FUZZY_VERIFICATION=false

# -----------------------------------------------------------------------------
# Inngest
# -----------------------------------------------------------------------------
# Get from https://app.inngest.com
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# For production:
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
