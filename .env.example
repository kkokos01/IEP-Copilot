# =============================================================================
# IEP Copilot - Environment Variables
# =============================================================================
# 1. Copy this to .env.local for development
# 2. Fill in ONLY the REQUIRED variables first
# 3. Add OPTIONAL variables as needed

# -----------------------------------------------------------------------------
# REQUIRED VARIABLES (Must fill these for app to work)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

GCP_PROJECT_ID=your-gcp-project-id
DOCAI_LOCATION=us  # or 'eu'
DOCAI_PROCESSOR_ID=your-processor-id

ANTHROPIC_API_KEY=sk-ant-your-api-key

INNGEST_EVENT_KEY=iep_your-event-key
INNGEST_SIGNING_KEY=signkey_your-signing-key

# -----------------------------------------------------------------------------
# GCP AUTHENTICATION (Choose ONE method)
# -----------------------------------------------------------------------------
# Method 1: Workload Identity Federation (Vercel Production)
GCP_WIF_CREDENTIALS_JSON={"type":"external_account",...}

# Method 2: Service Account JSON (Local Dev Only)
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Method 3: File Path (Local Dev Only)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# -----------------------------------------------------------------------------
# OPTIONAL VARIABLES (Leave commented unless needed)
# -----------------------------------------------------------------------------
# For type generation (optional)
# SUPABASE_PROJECT_ID=your-project-id

# Anthropic model (optional, defaults to claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App URLs (optional, defaults to localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags (optional, both default to false)
# ENABLE_SERVER_PDF_RENDER=false
# ENABLE_FUZZY_VERIFICATION=false
